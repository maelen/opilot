{
  "$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
  "extends": [
    "ultracite/biome/core",
    "ultracite/biome/vitest",
    "ultracite/biome/react"
  ],
  "formatter": {
    "enabled": true,
    "lineWidth": 120,
    "useEditorconfig": true
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "correctness": {
        "useQwikValidLexicalScope": "off"
      },
      "performance": {
        "noBarrelFile": "off",
        "useTopLevelRegex": "off",
        "noNamespaceImport": "off"
      },
      "style": {
        "useConsistentMemberAccessibility": "off",
        "noExportedImports": "off",
        "noEnum": "off"
      },
      "complexity": {
        "noVoid": "off"
      },
      "suspicious": {
        "noTemplateCurlyInString": "off"
      }
    }
  },
  "overrides": [
    {
      "includes": ["**/*.test.ts", "**/test/**"],
      "linter": {
        "rules": {
          "style": {
            "noParameterProperties": "off"
          }
        }
      }
    }
  ],
  "javascript": {
    "formatter": {
      "arrowParentheses": "asNeeded",
      "quoteStyle": "single",
      "semicolons": "always",
      "trailingCommas": "none"
    },
    "parser": {
      "unsafeParameterDecoratorsEnabled": true
    }
  },
  "files": {
    "includes": [
      "src/**/*.ts",
      "src/**/*.tsx",
      "!src/sidebar.ts",
      "!src/sidebar.test.ts",
      "!.*",
      "!.*/**/*",
      "!coverage/**/*",
      "!dist/**/*",
      "!node_modules/**/*"
    ],
    "ignoreUnknown": true
  }
}
